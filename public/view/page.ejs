<%-include('partials/header')%>
<div class="page">
    <div class="top">
        <div class="image">
            <img src="<%=url%>" alt="">
        </div>
        <dic class="details">
            <h1><%=title%></h1>
            <p class="about">
                <%=content%>
            </p>
            <div class="three">
                <p class="overview box" ><span>01</span>
                    overview
                </p>
                
                <p class='internalSturture box '>
                    <span>02</span>
                    internal structure
                </p>
                <p class="surface box">
                    <span>03</span>
                    surface geology
                </p>
            </div>
        </div>
    </div>
    <div class="bottom">
        <div class="rotationTime BOX">
            <span>ROTATION TIME</span>
            <%=rotate%>
        </div>
        <div class="revolutionTime BOX">
            <span>REVOLUTION TIME</span>
            <%=revolve%>
        </div>
        <div class="radius BOX" >
            <span>RADIUDS</span>
            <%=radi%>
        </div>
        <div class="averageTemp BOX">
            <span>AVERAGE TEMP</span>
            <%=temp%>
        </div>
    </div>
</div>

</body>
<script>
    //main pages
